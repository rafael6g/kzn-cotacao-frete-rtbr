# =============================================================
# CONFIGURAÇÃO DA APLICAÇÃO
# =============================================================
APP_NAME="Sistema de Cotações"
APP_ENV=development   # development | production
APP_PORT=8000
SECRET_KEY=troque-por-uma-chave-secreta-forte

# =============================================================
# XANO — Banco de dados (REST API)
# =============================================================
# URL base da sua instância Xano (ex: https://x8ki-letl-twmt.n7.xano.io)
XANO_BASE_URL=https://xxxx-xxxx-xxxx.b2.xano.io
XANO_API_GROUP=/api:XXXXXXXX

# Endpoints (apenas o sufixo após o grupo)
XANO_EP_CONFIG_SITE=/configuracao_site
XANO_EP_LOTE=/lote_cotacao
XANO_EP_CACHE=/cache_consulta
XANO_EP_ITEM=/item_cotacao

# =============================================================
# QUALP — Credenciais de login (https://qualp.com.br)
# =============================================================
QUALP_USUARIO=seu-email@empresa.com
QUALP_SENHA=sua-senha-aqui

# =============================================================
# PLAYWRIGHT
# =============================================================
PLAYWRIGHT_HEADLESS=true          # false para ver o browser (dev)
PLAYWRIGHT_TIMEOUT_MS=30000           # timeout por operação (ms)
PLAYWRIGHT_RESULTADO_TIMEOUT_MS=90000 # timeout espera pelo resultado da rota (rotas longas ~60s)
PLAYWRIGHT_SLOW_MO_MS=0               # delay entre ações (0 = desabilitado)

# =============================================================
# PROCESSAMENTO
# =============================================================
DELAY_PADRAO_SEGUNDOS=15          # delay entre consultas no site
MAX_RETENTATIVAS=2                # tentativas antes de marcar como erro
UPLOADS_DIR=uploads
OUTPUTS_DIR=outputs
