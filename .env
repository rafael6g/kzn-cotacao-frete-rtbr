# =============================================================
# CONFIGURAÇÃO DA APLICAÇÃO
# =============================================================
APP_NAME="Sistema de Cotações"
APP_ENV=development
APP_PORT=8000
SECRET_KEY=troque-por-uma-chave-secreta-forte

# =============================================================
# XANO — Banco de dados (REST API)
# =============================================================
XANO_BASE_URL=https://xd23-clr8-wwle.b2.xano.io
XANO_API_GROUP=/api:GYIBn8W3

XANO_EP_CONFIG_SITE=/configuracao_site
XANO_EP_LOTE=/lote_cotacao
XANO_EP_CACHE=/cache_consulta
XANO_EP_ITEM=/item_cotacao

# =============================================================
# PLAYWRIGHT
# =============================================================
PLAYWRIGHT_HEADLESS=false
PLAYWRIGHT_TIMEOUT_MS=30000
PLAYWRIGHT_SLOW_MO_MS=0

# =============================================================
# PROCESSAMENTO
# =============================================================
DELAY_PADRAO_SEGUNDOS=15
MAX_RETENTATIVAS=2
UPLOADS_DIR=uploads
OUTPUTS_DIR=outputs
